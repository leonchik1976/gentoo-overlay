# @FUNCTION: n8n_pnpm_deps_add_src_uri
# @DESCRIPTION:
# Verify the requested n8n version and append its dependency closure to SRC_URI.
n8n_pnpm_deps_add_src_uri() {
	[[ $# -eq 1 ]] || die "${FUNCNAME}: expected one n8n version argument"
	[[ ${1} == ${N8N_PNPM_DEPS_VERSION} ]] ||
		die "${FUNCNAME}: dependency metadata is for n8n-${N8N_PNPM_DEPS_VERSION}, not n8n-${1}"
	SRC_URI+=" ${N8N_PNPM_SRC_URI[*]}"
}
