# @DESCRIPTION:
# Verify the n8n release and append the runner-specific closure.
n8n_task_runners_pnpm_add_src_uri() {
	[[ $# -eq 1 ]] || die "${FUNCNAME}: expected one n8n version argument"
	[[ ${1} == ${N8N_TASK_RUNNERS_PNPM_VERSION} ]] ||
		die "${FUNCNAME}: metadata is for n8n-${N8N_TASK_RUNNERS_PNPM_VERSION}, not n8n-${1}"
	SRC_URI+=" ${N8N_TASK_RUNNERS_PNPM_SRC_URI[*]}"
}
